# Base64-encoded service account JSON for the crm-intake@<project>.iam.gserviceaccount.com
# service account (roles/datastore.user only). Generate locally with:
#   base64 -w0 path/to/key.json   (Linux/macOS)
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("key.json"))   (PowerShell)
FIREBASE_SERVICE_ACCOUNT=

# Random 64-hex-char secret used to sign session JWTs. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=
